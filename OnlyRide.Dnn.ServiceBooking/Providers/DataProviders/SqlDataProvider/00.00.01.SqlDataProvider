        [VehicleId] INT NOT NULL IDENTITY(1,1)
            CONSTRAINT [PK_OnlyRide_Vehicles] PRIMARY KEY CLUSTERED,
        [BookingId] INT NOT NULL,
        [VehicleType] NVARCHAR(100) NOT NULL,
        [Brand] NVARCHAR(100) NULL,
        [Model] NVARCHAR(100) NULL,
