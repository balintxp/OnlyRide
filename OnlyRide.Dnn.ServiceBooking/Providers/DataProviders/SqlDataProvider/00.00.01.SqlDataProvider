IF NOT EXISTS (SELECT * FROM sysobjects WHERE id = 
    OBJECT_ID(N'{databaseOwner}[{objectQualifier}OnlyRide_Vehicles]'))
BEGIN
    CREATE TABLE {databaseOwner}[{objectQualifier}OnlyRide_Vehicles]
