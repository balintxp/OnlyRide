@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<IEnumerable<OnlyRide.Dnn.ServiceBooking.Models.Booking>>
@using DotNetNuke.Web.Mvc.Helpers

<link rel="stylesheet" href="/DesktopModules/MVC/OnlyRide.Dnn.ServiceBooking/module.css">

@{
    var hu = new System.Globalization.CultureInfo("hu-HU");
    var today = DateTime.Today;
    int diff = (7 + (today.DayOfWeek - DayOfWeek.Monday)) % 7;
    int weekOffset = ViewBag.WeekOffset ?? 0;
    var monday = today.AddDays(-1 * diff).AddDays(weekOffset * 7).Date;
    var weekNum = hu.Calendar.GetWeekOfYear(monday, System.Globalization.CalendarWeekRule.FirstFourDayWeek, DayOfWeek.Monday);
}

<div class="onlyride-calendar">
    @if (Dnn.User.UserID <= 0)
    {
        <div class="onlyride-login-banner">
            A foglaláshoz kérjük
            <a href="@DotNetNuke.Common.Globals.LoginURL(Request.RawUrl, false)">jelentkezzen be</a>!
        </div>
    }
    <div class="calendar-controls">
        <a href="@Url.Action("Index", "Booking", new { weekOffset = (int)ViewBag.WeekOffset - 1, mid = Dnn.ModuleContext.ModuleId })" class="dnnSecondaryAction">&lt;</a>
        <span class="week-selector">@monday.Year. @weekNum. hét (@monday.ToString("MMM. dd.", hu) - @monday.AddDays(6).ToString("MMM. dd.", hu))</span>
        <a href="@Url.Action("Index", "Booking", new { weekOffset = (int)ViewBag.WeekOffset + 1, mid = Dnn.ModuleContext.ModuleId })" class="dnnSecondaryAction">&gt;</a>

        <div class="calendar-legend">
            <span class="legend-item"><span class="dot szabad"></span> Szabad</span>
            <span class="legend-item"><span class="dot foglalt"></span> Foglalt</span>
            <span class="legend-item"><span class="dot sajat"></span> Saját</span>
        </div>
    </div>

    <div class="calendar-grid">
        <div class="grid-header"></div>
        @for (int i = 0; i < 7; i++)
        {
            var dayDate = monday.AddDays(i);
            <div class="grid-header">
                @hu.TextInfo.ToTitleCase(dayDate.ToString("dddd", hu))<br />
                <small>@dayDate.ToString("MMM. dd.", hu)</small>
            </div>
        }

        @for (int hour = 8; hour <= 15; hour++)
        {
            <div class="time-label">@hour:00</div>
            for (int day = 0; day < 7; day++)
            {
                var currentSlotDate = monday.AddDays(day).AddHours(hour);
                var booking = Model.FirstOrDefault(b => b.CreatedOnDate.Date == currentSlotDate.Date && b.CreatedOnDate.Hour == hour && b.Status != "Lemondva");
                bool isPast = currentSlotDate < DateTime.Now;
                string statusClass = "status-szabad";
                string statusText = "Szabad";
                string actionUrl = "#";

                if (isPast && booking == null)
                {
                    statusClass = "status-lejart";
                    statusText = "";
                }
                else if (booking != null)
                {
                    bool isMine = booking.UserId == Dnn.User.UserID;
                    bool isAdmin = Dnn.User.IsSuperUser || Dnn.ModuleContext.IsEditable;
                    statusClass = isMine ? "status-sajat" : "status-foglalt";
                    statusText = isMine ? "Saját" : (isAdmin ? "Foglalt (admin)" : "Foglalt");
                    actionUrl = (isMine || isAdmin) ? string.Format("{0}?bookingId={1}&mid={2}", Url.Action("Edit", "Booking"), booking.BookingId, Dnn.ModuleContext.ModuleId) : "#";
                }
                else if (Dnn.User.UserID > 0)
                {
                    statusClass = "status-szabad";
                    statusText = "Szabad";
                    actionUrl = Url.Action("Edit", "Booking", new { date = currentSlotDate.ToString("yyyy-MM-dd HH:mm") });
                }
                <div class="slot-card @statusClass"
                     onclick="location.href='@actionUrl'">
                    @statusText
                </div>
            }
        }
    </div>
</div>