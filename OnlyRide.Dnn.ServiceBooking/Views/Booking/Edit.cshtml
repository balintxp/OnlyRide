@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<OnlyRide.Dnn.ServiceBooking.Models.Booking>
@using DotNetNuke.Web.Mvc.Helpers


@{
    // Változók előkészítése
    bool isAdmin = Dnn.User.IsSuperUser || Dnn.ModuleContext.IsEditable;
    bool isEditable = ViewBag.IsEditable ?? true;
    var vehicle = ViewBag.Vehicle as OnlyRide.Dnn.ServiceBooking.Models.Vehicle;
}

<div class="onlyride-edit-card">
    @* Admin nézet - foglalás részletei + szerkesztési lehetőség a szerviz lezárásához*@
    @if (isAdmin && Model.BookingId > 0)
    {
        <h2>Foglalás részletei</h2>

        @* Foglalás adatai - csak olvasható összefoglaló *@
        <div class="onlyride-detail-card">
            <div class="onlyride-detail-row">
                <span class="onlyride-detail-label">Foglaló neve</span>
                <span class="onlyride-detail-value">@(ViewBag.BookingUserName ?? "-")</span>
            </div>
            <div class="onlyride-detail-row">
                <span class="onlyride-detail-label">Email</span>
                <span class="onlyride-detail-value">@(ViewBag.BookingUserEmail ?? "-")</span>
            </div>
            <div class="onlyride-detail-row">
                <span class="onlyride-detail-label">Időpont</span>
                <span class="onlyride-detail-value">@Model.CreatedOnDate.ToString("yyyy. MM. dd. HH:mm")</span>
            </div>
            <div class="onlyride-detail-row">
                <span class="onlyride-detail-label">Státusz</span>
                <span class="onlyride-detail-value">@Model.Status</span>
            </div>
            <div class="onlyride-detail-row">
                <span class="onlyride-detail-label">Szolgáltatás</span>
                <span class="onlyride-detail-value">
                    @{
                        var serviceTypes = (IEnumerable<OnlyRide.Dnn.ServiceBooking.Models.ServiceType>)ViewBag.ServiceTypes;
                        var selectedSt = serviceTypes.FirstOrDefault(s => s.ServiceTypeId == Model.ServiceTypeId);
                    }
                    @(selectedSt != null ? selectedSt.Name : "-")
                </span>
            </div>
            <div class="onlyride-detail-row">
                <span class="onlyride-detail-label">Becsült ár</span>
                <span class="onlyride-detail-value">@(selectedSt != null ? selectedSt.BasePrice + " Ft" : "-")</span>
            </div>
            <div class="onlyride-detail-row">
                <span class="onlyride-detail-label">Becsült idő</span>
                <span class="onlyride-detail-value">@(selectedSt != null ? selectedSt.EstimatedMinutes + " perc" : "-")</span>
            </div>
            <div class="onlyride-detail-row">
                <span class="onlyride-detail-label">Jármű típusa</span>
                <span class="onlyride-detail-value">@(vehicle != null ? vehicle.VehicleType : "-")</span>
            </div>
            <div class="onlyride-detail-row">
                <span class="onlyride-detail-label">Márka / Modell</span>
                <span class="onlyride-detail-value">@(vehicle != null ? vehicle.Brand + " " + vehicle.Model : "-")</span>
            </div>
            <div class="onlyride-detail-row">
                <span class="onlyride-detail-label">Sorozatszám</span>
                <span class="onlyride-detail-value">@(vehicle != null ? vehicle.SerialNumber : "-")</span>
            </div>
            <div class="onlyride-detail-row">
                <span class="onlyride-detail-label">Hiba leírása</span>
                <span class="onlyride-detail-value">@(Model.CustomNote ?? "-")</span>
            </div>
        </div>

        @* Admin szerkeszthető mezők - szerviz lezáráshoz *@
        <form action="@Url.Action("Edit", "Booking", new { mid = Dnn.ModuleContext.ModuleId, tabid = Dnn.PortalSettings.ActiveTab.TabID })" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="mid" value="@Dnn.ModuleContext.ModuleId" />
            <input type="hidden" name="BookingId" value="@Model.BookingId" />
            <input type="hidden" name="IsAdminForm" value="true" />

            <h3>Szerviz lezárása</h3>

            <div class="onlyride-form-group">
                <label>Státusz</label>
                <select name="Status" class="form-control">
                    <option value="Folyamatban" @(Model.Status == "Folyamatban" ? "selected" : "")>Folyamatban</option>
                    <option value="Kész" @(Model.Status == "Kész" ? "selected" : "")>Kész</option>
                </select>
            </div>
            <div class="onlyride-form-group">
                <label>Tényleges idő (perc)</label>
                <input type="number" name="ActualMinutes" class="form-control"
                       value="@(Model.ActualMinutes.HasValue ? Model.ActualMinutes.ToString() : "")"
                       placeholder="pl. 45" />
            </div>
            <div class="onlyride-form-group">
                <label>Tényleges ár (Ft)</label>
                <input type="number" name="ActualPrice" class="form-control"
                       value="@(Model.ActualPrice.HasValue ? Model.ActualPrice.ToString() : "")"
                       placeholder="pl. 8000" />
            </div>

            <div class="onlyride-actions">
                <button type="submit" class="btn-confirm">Mentés</button>
                <a href="@Url.Action("Cancel", "Booking", new { bookingId = Model.BookingId })"
                   class="btn-cancel"
                   onclick="return confirm('Biztosan lemondja a foglalást?');">
                    Lemondás
                </a>
                <a href="@Url.Action("Index", "Booking")" class="btn-cancel">Mégse</a>
            </div>
        </form>
    }

    @*User nézet*@
    else
    {
        <h2>Időpont foglalása</h2>

        <form action="@Url.Action("Edit", "Booking")?mid=@Dnn.ModuleContext.ModuleId&tabid=@Dnn.PortalSettings.ActiveTab.TabID" method="post">
            @Html.AntiForgeryToken()

            @* DNN routing mezők *@
            <input type="hidden" name="mid" value="@Dnn.ModuleContext.ModuleId" />
            <input type="hidden" name="BookingId" value="@Model.BookingId" />
            <input type="hidden" name="ModuleId" value="@Dnn.ModuleContext.ModuleId" />
            <input type="hidden" name="SlotId" value="@Model.SlotId" />
            <input type="hidden" name="UserId" value="@Dnn.User.UserID" />

            @* Időpont - mindig csak olvasható *@
            <div class="onlyride-form-group">
                <label>Választott időpont</label>
                <input type="text" value="@Model.CreatedOnDate.ToString("yyyy. MM. dd. HH:mm")" readonly style="background:#f5f5f5;" />
                <input type="hidden" name="CreatedOnDate" value="@Model.CreatedOnDate.ToString("yyyy-MM-dd HH:mm")" />
            </div>

            @* Szolgáltatás típusa - disabled ha nem szerkeszthető *@
            <div class="onlyride-form-group">
                <label>Szolgáltatás típusa</label>
                <select name="ServiceTypeId" class="form-control" id="serviceTypeSelect"
                        onchange="updateEstimate()"
                        @(!isEditable ? "disabled" : "")>
                    @foreach (var st in (IEnumerable<OnlyRide.Dnn.ServiceBooking.Models.ServiceType>)ViewBag.ServiceTypes)
                    {
                        <option value="@st.ServiceTypeId"
                                data-price="@st.BasePrice"
                                data-minutes="@st.EstimatedMinutes"
                                @(Model.ServiceTypeId == st.ServiceTypeId ? "selected" : "")>
                            @st.Name
                        </option>
                    }
                </select>
            </div>

            @* Becsült ár és idő - automatikusan töltődik JS-sel *@
            <div class="onlyride-form-group">
                <label>Becsült ár és idő</label>
                <input type="text" id="estimateDisplay" readonly style="background:#f5f5f5;" />
            </div>

            <script>
                function updateEstimate() {
                    var select = document.getElementById('serviceTypeSelect');
                    var option = select.options[select.selectedIndex];
                    var price = option.getAttribute('data-price');
                    var minutes = option.getAttribute('data-minutes');
                    document.getElementById('estimateDisplay').value = price + ' Ft  |  ' + minutes + ' perc';
                }
                updateEstimate();
            </script>

            @* Jármű adatok *@
            <div class="onlyride-form-group">
                <label>Jármű típusa</label>
                <select name="VehicleType" class="form-control"
                        onchange="document.getElementById('egyeb-mezo').style.display = this.value == 'Egyéb' ? 'block' : 'none'"
                        @(!isEditable ? "disabled" : "")>
                    @foreach (var vt in new[] { "Elektromos roller", "Elektromos bicikli", "Hoverboard", "Elektromos gördeszka", "Egyéb" })
                    {
                        <option value="@vt" @(vehicle != null && vehicle.VehicleType == vt ? "selected" : "")>@vt</option>
                    }
                </select>
            </div>
            <div class="onlyride-form-group" id="egyeb-mezo" style="display:none;">
                <label>Egyéb jármű leírása</label>
                <input type="text" name="VehicleNotes" class="form-control"
                       value="@(vehicle != null ? vehicle.Notes : "")"
                       @(!isEditable ? "readonly style='background:#f5f5f5;'" : "") />
            </div>
            <div class="onlyride-form-group">
                <label>Márka</label>
                <input type="text" name="Brand" class="form-control"
                       value="@(vehicle != null ? vehicle.Brand : "")"
                       @(!isEditable ? "readonly style='background:#f5f5f5;'" : "") />
            </div>
            <div class="onlyride-form-group">
                <label>Modell</label>
                <input type="text" name="VehicleModel" class="form-control"
                       value="@(vehicle != null ? vehicle.Model : "")"
                       @(!isEditable ? "readonly style='background:#f5f5f5;'" : "") />
            </div>
            <div class="onlyride-form-group">
                <label>Sorozatszám</label>
                <input type="text" name="SerialNumber" class="form-control"
                       value="@(vehicle != null ? vehicle.SerialNumber : "")"
                       @(!isEditable ? "readonly style='background:#f5f5f5;'" : "") />
            </div>

            @* Hiba leírása *@
            <div class="onlyride-form-group">
                <label>Hiba leírása</label>
                <textarea name="CustomNote" rows="4" placeholder="Írd le a problémát..."
                          @(!isEditable ? "readonly style='background:#f5f5f5;'" : "")>@Model.CustomNote</textarea>
            </div>

            @* Gombok *@
            <div class="onlyride-actions">
                @if (isEditable)
                {
                    <button type="submit" class="btn-confirm">Foglalás megerősítése</button>
                }
                @if (Model.BookingId > 0 && (Model.UserId == Dnn.User.UserID || Dnn.User.IsSuperUser || Dnn.ModuleContext.IsEditable))
                {
                    <a href="@Url.Action("Cancel", "Booking", new { bookingId = Model.BookingId })"
                       class="btn-cancel"
                       onclick="return confirm('Biztosan lemondja a foglalást?');">
                        Lemondás
                    </a>
                }
                <a href="@Url.Action("Index", "Booking")" class="btn-cancel">Mégse</a>
            </div>
        </form>
    }

</div>